# ─── EmailJS (client-side email sending) ───────────────────────────────────────
# Get these values from https://www.emailjs.com (free account)
#
# 1. Create an account at https://www.emailjs.com
# 2. "Email Services" → Connect Gmail / Outlook / etc. → copy the Service ID
# 3. "Email Templates" → Create template using these variables:
#
#    Subject:  Verify your email – Nautical Archive Digital Library
#
#    Body (HTML or text):
#      Dear {{to_name}},
#
#      Thank you for registering with the Nautical Archive Digital Library.
#      Please verify your email by clicking the link below:
#
#      {{verification_url}}
#
#      If you did not create an account, please ignore this email.
#
#      Best regards,
#      {{app_name}}
#
# 4. "Account" → copy your Public Key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
